<div data-controller="collapse" data-collapse-storage-key-value="customers-filters-open" data-collapse-default-open-value="false">
  <%= search_form_for @q, url: customers_path, method: :get do |f| %>
    <!-- Główny pasek wyszukiwania -->
    <div class="flex items-center gap-1.5 bg-base-100 rounded-t-lg shadow-sm px-2 py-4 border-b border-base-200">
      <!-- Pole wyszukiwania -->
      <div class="flex flex-1 justify-center min-w-0">
        <div class="relative w-full max-w-4xl">
          <span class="absolute left-2.5 top-1/2 -translate-y-1/2 pointer-events-none text-text-muted">
            <%= lucide_icon('search', class: 'w-3.5 h-3.5') %>
          </span>
          <%= f.search_field :first_name_or_last_name_or_platform_username_cont,
              placeholder: "Szukaj po imieniu, nazwisku lub nicku...",
              class: "input input-md input-bordered w-full pl-8 bg-transparent border-base-200 focus:border-primary" %>
        </div>
      </div>
      <!-- Filtry toggle -->
      <button
        type="button"
        data-action="click->collapse#toggle"
        class="btn btn-sm btn-ghost gap-1.5 shrink-0"
      >
        <%= lucide_icon('sliders-horizontal', class: 'w-3.5 h-3.5') %>
        <span class="hidden sm:inline text-xs">Filtry</span>
        <%= lucide_icon('chevron-down', class: 'w-3 h-3 opacity-50 transition-transform', data: { collapse_target: 'icon' }) %>
      </button>
    </div>
    <!-- Panel filtrów (zwijany) -->
    <div data-collapse-target="content" class="bg-base-100 shadow-sm px-4 py-3 border-b border-base-200">
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        <div class="form-control">
          <%= f.label :email_cont, "Email", class: "label label-text text-xs pb-1" %>
          <%= f.search_field :email_cont, placeholder: "Filtruj po emailu...", class: "input input-sm input-bordered w-full" %>
        </div>
        <div class="form-control">
          <%= f.label :phone_cont, "Telefon", class: "label label-text text-xs pb-1" %>
          <%= f.search_field :phone_cont, placeholder: "Filtruj po telefonie...", class: "input input-sm input-bordered w-full" %>
        </div>
        <div class="form-control">
          <label class="label label-text text-xs pb-1">Źródło</label>
          <select name="platform" class="select select-sm select-bordered w-full">
            <option value="" <%= 'selected' if params[:platform].blank? %>>Wszystkie</option>
            <option value="tiktok" <%= 'selected' if params[:platform] == 'tiktok' %>>TikTok</option>
            <option value="manual" <%= 'selected' if params[:platform] == 'manual' %>>Ręczny</option>
          </select>
        </div>
      </div>
      <div class="flex justify-end gap-2 mt-4">
        <%= link_to "Wyczyść", customers_path, class: "btn btn-sm btn-ghost" %>
        <%= f.submit "Zastosuj filtry", class: "btn btn-sm btn-primary" %>
      </div>
    </div>
  <% end %>
</div>
