<div>
  <table class="table">
    <thead>
      <tr>
        <th class="label-text w-12">#</th>
        <th class="label-text">Klient</th>
        <th class="label-text">Email</th>
        <th class="label-text">Telefon</th>
        <th class="label-text text-end">Akcje</th>
      </tr>
    </thead>
    <tbody>
      <% @customers.each do |customer| %>
        <tr>
          <td class="text-base-content/40 text-sm tabular-nums"><%= customer.id %></td>
          <td>
            <div class="flex items-start gap-2">
              <div class="shrink-0 self-center">
                <% if customer.platform == "tiktok" %>
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/>
                  </svg>
                <% else %>
                  <%= lucide_icon('user', class: 'w-4 h-4 text-base-content/40') %>
                <% end %>
              </div>
              <div>
                <div class="font-medium"><%= customer.name %></div>
                <% if customer.platform == "tiktok" && customer.platform_username.present? %>
                  <div class="text-xs text-base-content/50 font-mono mt-0.5">@<%= customer.platform_username %></div>
                <% end %>
              </div>
            </div>
          </td>
          <td><%= customer.email.presence || '<span class="text-base-content/30">—</span>'.html_safe %></td>
          <td><%= customer.phone.presence || '<span class="text-base-content/30">—</span>'.html_safe %></td>
          <td class="text-end">
            <div class="dropdown dropdown-end">
              <div tabindex="0" role="button" class="btn btn-sm btn-ghost">
                <%= lucide_icon('more-vertical', class: 'w-4 h-4') %>
              </div>
              <ul tabindex="0" class="dropdown-content menu bg-base-100 rounded-box z-[1] w-52 p-2 shadow">
                <li>
                  <%= link_to edit_customer_path(customer), data: { turbo_frame: "customer_modal" } do %>
                    <%= lucide_icon('edit', class: 'w-4 h-4') %>
                    Edytuj
                  <% end %>
                </li>
                <li>
                  <%= link_to customer_path(customer), data: { turbo_method: :delete, turbo_confirm: "Na pewno usunąć?" }, class: "text-error" do %>
                    <%= lucide_icon('trash', class: 'w-4 h-4') %>
                    Usuń
                  <% end %>
                </li>
              </ul>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <div class="flex items-center justify-end gap-4 px-4 py-3 border-t border-base-200">
    <div class="flex items-center gap-2">
      <select
        onchange="window.location.href = this.value"
        class="select select-sm select-bordered bg-base-100 min-h-0 h-8 pr-8"
      >
        <% @per_page_options.each do |option| %>
          <option
            value="<%= customers_path(request.params.merge(per_page: option, page: 1)) %>"
            <%= 'selected' if @pagy.limit == option %>
          >
            <%= option %>
          </option>
        <% end %>
      </select>
    </div>
    <div class="flex items-center gap-1">
      <% if @pagy.page > 1 %>
        <%= link_to customers_path(request.params.merge(page: @pagy.page - 1)), class: "p-1 rounded hover:bg-base-200 transition-colors" do %>
          <%= lucide_icon('chevron-left', class: 'w-4 h-4') %>
        <% end %>
      <% else %>
        <span class="p-1 opacity-30"><%= lucide_icon('chevron-left', class: 'w-4 h-4') %></span>
      <% end %>
      <span class="px-2 tabular-nums"><%= @pagy.page %> / <%= @pagy.pages %></span>
      <% if @pagy.page < @pagy.pages %>
        <%= link_to customers_path(request.params.merge(page: @pagy.page + 1)), class: "p-1 rounded hover:bg-base-200 transition-colors" do %>
          <%= lucide_icon('chevron-right', class: 'w-4 h-4') %>
        <% end %>
      <% else %>
        <span class="p-1 opacity-30"><%= lucide_icon('chevron-right', class: 'w-4 h-4') %></span>
      <% end %>
    </div>
  </div>
</div>
