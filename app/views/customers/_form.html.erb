<%= form_with model: @customer, data: { turbo_frame: "_top" } do |f| %>
  <div class="space-y-4">
    <div class="grid grid-cols-2 gap-3">
      <div class="form-control">
        <%= f.label :first_name, "Imię *", class: "label label-text font-medium" %>
        <%= f.text_field :first_name,
              class: "input input-bordered w-full #{'input-error' if @customer.errors[:first_name].any?}",
              placeholder: "np. Jan",
              maxlength: 50 %>
        <% @customer.errors[:first_name].each do |msg| %>
          <p class="text-error text-sm mt-1"><%= msg %></p>
        <% end %>
      </div>
      <div class="form-control">
        <%= f.label :last_name, "Nazwisko", class: "label label-text font-medium" %>
        <%= f.text_field :last_name,
              class: "input input-bordered w-full #{'input-error' if @customer.errors[:last_name].any?}",
              placeholder: "np. Kowalski",
              maxlength: 50 %>
        <% @customer.errors[:last_name].each do |msg| %>
          <p class="text-error text-sm mt-1"><%= msg %></p>
        <% end %>
      </div>
    </div>

    <div class="form-control">
      <%= f.label :email, "Email", class: "label label-text font-medium" %>
      <%= f.email_field :email,
            class: "input input-bordered w-full #{'input-error' if @customer.errors[:email].any?}",
            placeholder: "jan@example.pl" %>
      <% @customer.errors[:email].each do |msg| %>
        <p class="text-error text-sm mt-1"><%= msg %></p>
      <% end %>
    </div>

    <div class="form-control">
      <%= f.label :phone, "Telefon", class: "label label-text font-medium" %>
      <%
        phone_prefixes = [
          ["+48",  "PL +48"],  ["+49",  "DE +49"],  ["+43",  "AT +43"],
          ["+32",  "BE +32"],  ["+45",  "DK +45"],  ["+33",  "FR +33"],
          ["+30",  "GR +30"],  ["+31",  "NL +31"],  ["+353", "IE +353"],
          ["+39",  "IT +39"],  ["+1",   "CA/US +1"], ["+47",  "NO +47"],
          ["+351", "PT +351"], ["+40",  "RO +40"],  ["+421", "SK +421"],
          ["+386", "SI +386"], ["+34",  "ES +34"],  ["+46",  "SE +46"],
          ["+41",  "CH +41"],  ["+380", "UA +380"], ["+44",  "GB +44"],
          ["+420", "CZ +420"], ["+36",  "HU +36"],
        ]
        stored_phone = @customer.phone.to_s
        detected_prefix = phone_prefixes.map(&:first).sort_by { |p| -p.length }.find { |p| stored_phone.start_with?(p) } || "+48"
        detected_number = stored_phone.delete_prefix(detected_prefix)
      %>
      <div class="flex gap-2">
        <select name="customer[phone_prefix]" class="select select-bordered w-28 shrink-0">
          <% phone_prefixes.each do |value, label| %>
            <option value="<%= value %>" <%= "selected" if detected_prefix == value %>><%= label %></option>
          <% end %>
        </select>
        <input type="tel"
               name="customer[phone_number]"
               class="input input-bordered flex-1 <%= 'input-error' if @customer.errors[:phone].any? %>"
               placeholder="123456789"
               value="<%= detected_number %>"
               maxlength="9"
               oninput="this.value = this.value.replace(/\D/g, '').slice(0, 9)">
      </div>
      <% @customer.errors[:phone].each do |msg| %>
        <p class="text-error text-sm mt-1"><%= msg %></p>
      <% end %>
    </div>

    <div class="form-control">
      <label class="label label-text font-medium">Źródło zamówienia</label>
      <select name="customer[platform]"
              class="select select-bordered w-full"
              onchange="document.getElementById('customer_nick_section').classList.toggle('hidden', this.value !== 'tiktok')">
        <option value="" <%= "selected" if @customer.platform.blank? %>>Osobiste</option>
        <option value="tiktok" <%= "selected" if @customer.platform == "tiktok" %>>TikTok</option>
      </select>
    </div>

    <div id="customer_nick_section" class="form-control <%= 'hidden' if @customer.platform != 'tiktok' %>">
      <%= f.label :platform_username, "Nick TikTok", class: "label label-text font-medium" %>
      <div class="input input-bordered flex items-center gap-2 w-full #{'input-error' if @customer.errors[:platform_username].any?}">
        <span class="text-base-content/40 select-none">@</span>
        <%= f.text_field :platform_username,
              class: "grow bg-transparent outline-none",
              placeholder: "twój_nick",
              maxlength: 24,
              oninput: "this.value = this.value.replace(/[^a-zA-Z0-9._]/g, '').slice(0, 24)" %>
      </div>
      <% @customer.errors[:platform_username].each do |msg| %>
        <p class="text-error text-sm mt-1"><%= msg %></p>
      <% end %>
    </div>
  </div>

  <div class="modal-action mt-6">
    <%= button_tag type: "button", class: "btn btn-ghost",
        onclick: "document.getElementById('customer_modal').innerHTML = ''" do %>
      Anuluj
    <% end %>
    <%= f.submit "Zapisz", class: "btn btn-primary" %>
  </div>
<% end %>
