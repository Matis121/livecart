<div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-4 mb-6">
  <%= render "shared/page_header",
      title: transmission.name,
      subtitle: "Utworzono #{l(transmission.created_at, format: :long)}",
      back_path: transmissions_path,
      back_label: "Powrót do transmisji" %>
  <div class="dropdown dropdown-end">
    <label tabindex="0" class="btn btn-sm btn-ghost gap-2">
      <%= lucide_icon("ellipsis-vertical", class: "w-4 h-4") %>
    </label>
    <ul tabindex="0" class="dropdown-content menu z-10 mt-2 w-52 rounded-box bg-base-100 p-2 shadow-lg border border-base-200/60">
      <li>
        <%= link_to edit_transmission_path(transmission), class: "gap-2", data: { turbo_frame: "transmission_modal" } do %>
          <%= lucide_icon("edit", class: "w-4 h-4") %>
          Edytuj
        <% end %>
      </li>
    </ul>
  </div>
</div>
