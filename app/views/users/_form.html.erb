<%= form_with model: @user, url: @user.new_record? ? employees_path : employee_path(@user), data: { turbo_frame: "_top" }, local: true do |f| %>
  <div class="space-y-3">
    <div class="form-control">
      <%= f.label :email, "Email", class: "label" %>
      <%= f.email_field :email, class: "input input-bordered w-full focus:input-primary #{@user.errors[:email].any? ? 'input-error' : ''}", placeholder: "np. jan@firma.pl" %>
      <% @user.errors[:email].each do |message| %>
        <label class="label"><span class="text-error text-sm"><%= message %></span></label>
      <% end %>
    </div>

    <% if @user.new_record? %>
      <div class="form-control">
        <%= f.label :password, "Hasło", class: "label" %>
        <%= f.password_field :password, class: "input input-bordered w-full focus:input-primary #{@user.errors[:password].any? ? 'input-error' : ''}", placeholder: "Minimum 6 znaków" %>
        <% @user.errors[:password].each do |message| %>
          <label class="label"><span class="text-error text-sm"><%= message %></span></label>
        <% end %>
      </div>

      <div class="form-control">
        <%= f.label :password_confirmation, "Powtórz hasło", class: "label" %>
        <%= f.password_field :password_confirmation, class: "input input-bordered w-full focus:input-primary #{@user.errors[:password_confirmation].any? ? 'input-error' : ''}" %>
        <% @user.errors[:password_confirmation].each do |message| %>
          <label class="label"><span class="text-error text-sm"><%= message %></span></label>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="modal-action">
    <button type="button" class="btn btn-ghost" onclick="document.getElementById('user_modal').innerHTML = ''">Anuluj</button>
    <%= f.submit @user.new_record? ? "Utwórz pracownika" : "Zapisz zmiany", class: "btn btn-primary" %>
  </div>
<% end %>
