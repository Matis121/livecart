<div class="p-6 space-y-6 max-w-7xl mx-auto">
  <%# ─── Header ─────────────────────────────────────────────────────── %>
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold">Dashboard</h1>
      <p class="text-base-content/50 text-sm mt-0.5">
        <%= current_account.company_name %> &middot; <%= l(Date.today, format: :long) %>
      </p>
    </div>
    <%= link_to new_order_path, class: "btn btn-primary btn-sm gap-2" do %>
      <%= lucide_icon "plus", class: "w-4 h-4" %>
      Nowe zamówienie
    <% end %>
  </div>
  <%# ─── Stats grid ──────────────────────────────────────────────────── %>
  <div class="grid grid-cols-2 xl:grid-cols-4 gap-4">
    <div class="bg-base-100 rounded-xl p-5 shadow-sm">
      <div class="flex items-center justify-between mb-4">
        <span class="text-xs font-medium text-base-content/50 uppercase tracking-wide">Zamówienia dziś</span>
        <div class="w-8 h-8 bg-base-200 rounded-lg flex items-center justify-center shrink-0">
          <%= lucide_icon "shopping-cart", class: "w-4 h-4 text-base-content/50" %>
        </div>
      </div>
      <div class="text-3xl font-bold tabular-nums"><%= @orders_count_today %></div>
      <div class="text-xs text-base-content/40 mt-1.5 flex items-center gap-1">
        <%= lucide_icon "calendar", class: "w-3 h-3" %>
        <%= @orders_count_month %> w tym miesiącu
      </div>
    </div>
    <div class="bg-base-100 rounded-xl p-5 shadow-sm">
      <div class="flex items-center justify-between mb-4">
        <span class="text-xs font-medium text-base-content/50 uppercase tracking-wide">Przychód (mies.)</span>
        <div class="w-8 h-8 bg-base-200 rounded-lg flex items-center justify-center shrink-0">
          <%= lucide_icon "banknote", class: "w-4 h-4 text-base-content/50" %>
        </div>
      </div>
      <div class="text-3xl font-bold tabular-nums">
        <%= number_to_currency(@revenue_this_month, unit: "zł", format: "%n %u", delimiter: "\u00a0", separator: ",", precision: 2) %>
      </div>
      <div class="text-xs text-base-content/40 mt-1.5 flex items-center gap-1">
        <%= lucide_icon "check-circle", class: "w-3 h-3" %>
        opłacone zamówienia
      </div>
    </div>
    <div class="bg-base-100 rounded-xl p-5 shadow-sm">
      <div class="flex items-center justify-between mb-4">
        <span class="text-xs font-medium text-base-content/50 uppercase tracking-wide">Klienci</span>
        <div class="w-8 h-8 bg-base-200 rounded-lg flex items-center justify-center shrink-0">
          <%= lucide_icon "users", class: "w-4 h-4 text-base-content/50" %>
        </div>
      </div>
      <div class="text-3xl font-bold tabular-nums"><%= @customers_count %></div>
      <div class="text-xs text-base-content/40 mt-1.5 flex items-center gap-1">
        <%= lucide_icon "user-plus", class: "w-3 h-3" %>
        +<%= @new_customers_this_month %> w tym miesiącu
      </div>
    </div>
    <div class="bg-base-100 rounded-xl p-5 shadow-sm">
      <div class="flex items-center justify-between mb-4">
        <span class="text-xs font-medium text-base-content/50 uppercase tracking-wide">Produkty</span>
        <div class="w-8 h-8 bg-base-200 rounded-lg flex items-center justify-center shrink-0">
          <%= lucide_icon "package", class: "w-4 h-4 text-base-content/50" %>
        </div>
      </div>
      <div class="text-3xl font-bold tabular-nums"><%= @products_count %></div>
      <div class="text-xs text-base-content/40 mt-1.5 flex items-center gap-1">
        <%= lucide_icon "layers", class: "w-3 h-3" %>
        w katalogu
      </div>
    </div>
  </div>
  <%# ─── Main content ────────────────────────────────────────────────── %>
  <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
    <%# Recent orders table %>
    <div class="xl:col-span-2 bg-base-100 rounded-xl shadow-sm overflow-hidden flex flex-col">
      <div class="flex items-center justify-between px-5 py-4 border-b border-base-200 shrink-0">
        <h2 class="font-semibold">Ostatnie zamówienia</h2>
        <%= link_to orders_path, class: "text-xs text-primary hover:underline flex items-center gap-1" do %>
          Zobacz wszystkie
          <%= lucide_icon "arrow-right", class: "w-3 h-3" %>
        <% end %>
      </div>
      <% if @recent_orders.any? %>
        <div class="overflow-x-auto">
          <table class="table table-sm">
            <thead>
              <tr class="text-base-content/40 text-xs uppercase">
                <th class="font-medium">Numer</th>
                <th class="font-medium">Klient</th>
                <th class="font-medium">Kwota</th>
                <th class="font-medium">Status</th>
                <th class="font-medium">Data</th>
              </tr>
            </thead>
            <tbody>
              <% @recent_orders.each do |order| %>
                <tr class="hover:bg-base-200/40 cursor-pointer transition-colors"
                    onclick="location.href='<%= order_path(order) %>'">
                  <td class="font-mono text-sm font-medium">
                    #<%= order.order_number %>
                  </td>
                  <td>
                    <% if order.customer %>
                      <span class="font-medium"><%= order.customer.name %></span>
                    <% elsif order.email.present? %>
                      <span class="text-base-content/60 text-sm"><%= order.email %></span>
                    <% else %>
                      <span class="text-base-content/30">—</span>
                    <% end %>
                  </td>
                  <td class="font-semibold tabular-nums">
                    <%= number_to_currency(order.total_amount, unit: "zł", format: "%n %u", delimiter: "\u00a0", separator: ",", precision: 2) %>
                  </td>
                  <td>
                    <%= render "dashboard/order_status_badge", status: order.status %>
                  </td>
                  <td class="text-base-content/40 text-xs whitespace-nowrap">
                    <%= order.created_at.strftime("%d.%m &middot; %H:%M").html_safe %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="flex flex-col items-center justify-center flex-1 py-16 text-base-content/30">
          <%= lucide_icon "inbox", class: "w-10 h-10 mb-3" %>
          <p class="text-sm">Brak zamówień</p>
        </div>
      <% end %>
    </div>
    <%# Right column %>
    <%# Quick actions %>
    <div class="bg-base-100 rounded-xl shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-base-200">
        <h2 class="font-semibold">Szybkie akcje</h2>
      </div>
      <div class="p-3 space-y-1">
        <%= link_to new_order_path, class: "flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-base-200 transition-colors group" do %>
          <div class="w-8 h-8 bg-base-200 rounded-lg flex items-center justify-center shrink-0 group-hover:bg-base-300 transition-colors">
            <%= lucide_icon "shopping-cart", class: "w-4 h-4 text-base-content/50" %>
          </div>
          <div class="min-w-0">
            <div class="text-sm font-medium">Nowe zamówienie</div>
            <div class="text-xs text-base-content/40">Utwórz zamówienie ręcznie</div>
          </div>
          <%= lucide_icon "chevron-right", class: "w-4 h-4 text-base-content/30 ml-auto" %>
        <% end %>
        <%= link_to new_product_path, class: "flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-base-200 transition-colors group" do %>
          <div class="w-8 h-8 bg-base-200 rounded-lg flex items-center justify-center shrink-0 group-hover:bg-base-300 transition-colors">
            <%= lucide_icon "package-plus", class: "w-4 h-4 text-base-content/50" %>
          </div>
          <div class="min-w-0">
            <div class="text-sm font-medium">Dodaj produkt</div>
            <div class="text-xs text-base-content/40">Nowy produkt do katalogu</div>
          </div>
          <%= lucide_icon "chevron-right", class: "w-4 h-4 text-base-content/30 ml-auto" %>
        <% end %>
        <%= link_to new_customer_path, class: "flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-base-200 transition-colors group" do %>
          <div class="w-8 h-8 bg-base-200 rounded-lg flex items-center justify-center shrink-0 group-hover:bg-base-300 transition-colors">
            <%= lucide_icon "user-plus", class: "w-4 h-4 text-base-content/50" %>
          </div>
          <div class="min-w-0">
            <div class="text-sm font-medium">Dodaj klienta</div>
            <div class="text-xs text-base-content/40">Nowy klient w bazie</div>
          </div>
          <%= lucide_icon "chevron-right", class: "w-4 h-4 text-base-content/30 ml-auto" %>
        <% end %>
        <%= link_to settings_root_path, class: "flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-base-200 transition-colors group" do %>
          <div class="w-8 h-8 bg-base-200 rounded-lg flex items-center justify-center shrink-0 group-hover:bg-base-300 transition-colors">
            <%= lucide_icon "settings", class: "w-4 h-4 text-base-content/50" %>
          </div>
          <div class="min-w-0">
            <div class="text-sm font-medium">Ustawienia</div>
            <div class="text-xs text-base-content/40">Konfiguracja sklepu</div>
          </div>
          <%= lucide_icon "chevron-right", class: "w-4 h-4 text-base-content/30 ml-auto" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
