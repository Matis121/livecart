<%# ─── Live Data / Stats (Adapted to match Relume aesthetics) ────────── %>
<div class="<%= header_class %>">
  <%= render "shared/page_header", title: "Dashboard", subtitle: "Przegląd aktywności sklepu" %>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
  <div class="<%= card_class %>">
    <div class="stat-label mb-2">Zamówienia dziś</div>
    <div class="stat-value"><%= @orders_count_today %></div>
    <div class="caption-text mt-2 text-emerald-600 flex items-center gap-1">
      <%= lucide_icon("trending-up", class: "w-4 h-4") %>
      <span>+<%= @orders_count_month %> w tym miesiącu</span>
    </div>
  </div>
  <div class="<%= card_class %>">
    <div class="stat-label mb-2">Przychód (mies.)</div>
    <div class="stat-value"><%= number_to_currency(@revenue_this_month) %></div>
    <div class="caption-text mt-2">opłaconych zamówień</div>
  </div>
  <div class="<%= card_class %>">
    <div class="stat-label mb-2">Nowi klienci</div>
    <div class="stat-value"><%= @customers_count %></div>
    <div class="caption-text mt-2 text-emerald-600 flex items-center gap-1">
      <%= lucide_icon("trending-up", class: "w-4 h-4") %>
      <span>+<%= @new_customers_this_month %> w tym miesiącu</span>
    </div>
  </div>
  <div class="<%= card_class %>">
    <div class="stat-label mb-2">Katalog</div>
    <div class="stat-value"><%= @products_count %></div>
    <div class="caption-text mt-2">aktywnych produktów</div>
  </div>
</div>
