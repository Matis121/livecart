<%= turbo_frame_tag "payment_section" do %>
  <h3 class="subsection-title mb-3">Płatność</h3>
  <%= form_with model: @order, url: update_payment_order_path(@order), method: :patch do |f| %>
    <div class="space-y-3">
      <div class="flex justify-between items-center">
        <span class="label-text">Sposób płatności</span>
        <%= f.text_field :payment_method, class: "input input-bordered input-sm w-44", placeholder: "np. Przelew" %>
      </div>
      <div class="flex justify-between items-center">
        <span class="label-text">Zapłacono</span>
        <div class="flex items-center gap-1">
          <%= f.number_field :paid_amount, step: 0.01, class: "input input-bordered input-sm w-28", placeholder: "0.00" %>
          <span class="label-text"><%= @order.currency %></span>
        </div>
      </div>
      <div class="flex justify-between items-center">
        <span class="label-text">Pobranie</span>
        <%= f.check_box :cash_on_delivery, class: "checkbox checkbox-sm" %>
      </div>
    </div>
    <div class="flex justify-end gap-2 mt-4">
      <%= link_to "Anuluj", order_path(@order), class: "btn btn-ghost btn-sm" %>
      <%= f.submit "Zapisz", class: "btn btn-primary btn-sm" %>
    </div>
  <% end %>
<% end %>
