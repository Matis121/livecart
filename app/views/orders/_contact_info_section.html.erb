<turbo-frame id="contact_info_section">
  <h3 class="subsection-title mb-3">Dane kontaktowe</h3>
  <%= link_to edit_contact_info_order_path(order), data: { turbo_frame: "contact_info_section" }, class: "block space-y-3 -mx-2 px-2 py-1 rounded-lg hover:bg-base-200/50 cursor-pointer transition-colors" do %>
    <div class="flex justify-between items-center">
      <span class="label-text">Email</span>
      <span class="body-text font-medium"><%= order.email.presence || "—" %></span>
    </div>
    <div class="flex justify-between items-center">
      <span class="label-text">Telefon</span>
      <span class="body-text font-medium"><%= order.phone.presence || "—" %></span>
    </div>
  <% end %>
</turbo-frame>
