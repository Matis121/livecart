<turbo-frame id="customer_section">
  <h3 class="subsection-title mb-3">Klient</h3>
  <%= link_to edit_customer_order_path(order), data: { turbo_frame: "customer_section" }, class: "block -mx-2 px-2 py-1 rounded-lg hover:bg-base-200/50 cursor-pointer transition-colors" do %>
    <% if order.customer.present? %>
      <div class="flex justify-between items-center">
        <span class="label-text">Nazwa</span>
        <span class="body-text font-medium"><%= order.customer.name %></span>
      </div>
    <% else %>
      <span class="label-text">Brak przypisanego klienta</span>
    <% end %>
  <% end %>
</turbo-frame>
