<turbo-frame id="customer_section">
  <div class="flex justify-between items-start mb-3">
    <h2 class="subsection-title">Klient</h2>
    <% if order.customer.present? %>
      <%= link_to "Zmień", edit_customer_order_path(order),
          data: { turbo_frame: "edit_customer" },
          class: "text-link" %>
    <% end %>
  </div>

  <% if order.customer.present? %>
    <div>
      <div class="caption-text mb-1">Nazwa</div>
      <div class="body-text font-medium"><%= order.customer.name %></div>
    </div>
  <% else %>
    <p class="body-secondary mb-3">Brak przypisanego klienta</p>
    <%= link_to "Przypisz klienta", edit_customer_order_path(order),
        data: { turbo_frame: "edit_customer" },
        class: "btn btn-sm" %>
  <% end %>

  <%= turbo_frame_tag "edit_customer" %>
</turbo-frame>

