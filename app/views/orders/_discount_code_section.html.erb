<turbo-frame id="discount_code_section">
  <div class="flex justify-between items-start mb-3">
    <h3 class="subsection-title">Kod rabatowy</h3>
    <%= link_to edit_discount_code_order_path(order),
        class: "btn btn-ghost btn-sm btn-square" do %>
      <%= lucide_icon "pencil", class: "w-4 h-4" %>
    <% end %>
  </div>
  <% if order.discount_name.present? %>
    <div class="space-y-3">
      <div class="flex justify-between items-center">
        <span class="label-text">Kod rabatowy</span>
        <span class="body-text font-medium"><%= order.discount_name.presence || "—" %></span>
      </div>
      <div class="flex justify-between items-center">
        <span class="label-text">Wartość</span>
        <span class="body-text font-medium"><%= number_to_currency(order.discount_amount, unit: order.currency) %></span>
      </div>
    </div>
  <% end %>
</turbo-frame>
