<turbo-frame id="discount_code_section">
  <h3 class="subsection-title mb-3">Kod rabatowy</h3>
  <%= link_to edit_discount_code_order_path(order), data: { turbo_frame: "discount_code_section" }, class: "block -mx-2 px-2 py-1 rounded-lg hover:bg-base-200/50 cursor-pointer transition-colors" do %>
    <% if order.discount_name.present? %>
      <div class="space-y-3">
        <div class="flex justify-between items-center">
          <span class="label-text">Kod</span>
          <span class="body-text font-medium"><%= order.discount_name %></span>
        </div>
        <div class="flex justify-between items-center">
          <span class="label-text">Wartość</span>
          <span class="body-text font-medium"><%= number_to_currency(order.discount_amount, unit: order.currency) %></span>
        </div>
      </div>
    <% else %>
      <span class="body-secondary">Brak kodu rabatowego</span>
    <% end %>
  <% end %>
</turbo-frame>
