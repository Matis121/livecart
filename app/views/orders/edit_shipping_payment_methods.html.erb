<%= turbo_frame_tag "shipping_payment_methods_section" do %>
  <h3 class="subsection-title mb-3">Wysyłka</h3>
  <%= form_with model: @order, url: update_shipping_payment_methods_order_path(@order), method: :patch do |f| %>
    <div class="space-y-3">
      <div class="flex justify-between items-center">
        <span class="label-text">Sposób wysyłki</span>
        <%= f.text_field :shipping_method, class: "input input-bordered input-sm w-44", placeholder: "np. Kurier" %>
      </div>
      <div class="flex justify-between items-center">
        <span class="label-text">Koszt wysyłki</span>
        <div class="flex items-center gap-1">
          <%= f.number_field :shipping_cost, step: 0.01, class: "input input-bordered input-sm w-28", placeholder: "0.00" %>
          <span class="label-text"><%= @order.currency %></span>
        </div>
      </div>
    </div>
    <div class="flex justify-end gap-2 mt-4">
      <%= link_to "Anuluj", order_path(@order), class: "btn btn-ghost btn-sm" %>
      <%= f.submit "Zapisz", class: "btn btn-primary btn-sm" %>
    </div>
  <% end %>
<% end %>
