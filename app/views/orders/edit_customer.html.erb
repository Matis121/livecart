<%= turbo_frame_tag "customer_section" do %>
  <h3 class="subsection-title mb-3">Klient</h3>
  <%= form_with model: @order, url: order_path(@order), method: :patch do |f| %>
    <div class="space-y-3">
      <div class="flex justify-between items-center">
        <span class="label-text">Nazwa</span>
        <%= f.select :customer_id,
            options_from_collection_for_select(@customers, :id, :name, @order.customer_id),
            { prompt: "Wybierz klienta..." },
            class: "select select-bordered select-sm w-44" %>
      </div>
    </div>
    <div class="flex justify-end gap-2 mt-4">
      <%= link_to "Anuluj", order_path(@order), class: "btn btn-ghost btn-sm" %>
      <%= f.submit "Przypisz", class: "btn btn-primary btn-sm" %>
    </div>
  <% end %>
<% end %>
