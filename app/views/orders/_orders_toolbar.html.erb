<div data-controller="collapse" data-collapse-storage-key-value="orders-filters-open" data-collapse-default-open-value="false">
  <%= search_form_for @q, url: orders_path, method: :get do |f| %>
    <%= hidden_field_tag :status, params[:status] if params[:status].present? %>
    <!-- Filtry statusu -->
    <div class="flex items-center gap-1 bg-base-100 rounded-lg shadow-sm px-3 py-2 mb-6 overflow-x-auto">
      <%= link_to orders_path(request.params.except('status', 'page')),
          class: "btn btn-sm shrink-0 gap-1.5 #{params[:status].blank? ? 'btn-primary' : 'btn-ghost'}" do %>
        Wszystkie
        <span class="<%= params[:status].blank? ? 'opacity-70' : 'opacity-50' %> tabular-nums text-xs">
          <%= @all_orders_count %>
        </span>
      <% end %>
      <div class="w-px h-4 bg-base-200 mx-1 shrink-0"></div>
      <div class="flex gap-2">
        <% Order::STATUS_NAMES.each do |key, name| %>
          <%= link_to orders_path(request.params.except('page').merge(status: key)),
            class: "btn btn-sm shrink-0 gap-1.5 #{params[:status] == key.to_s ? 'btn-primary' : 'btn-ghost'}" do %>
            <%= name %>
            <span class="<%= params[:status] == key.to_s ? 'opacity-70' : 'opacity-50' %> tabular-nums text-xs">
              <%= @all_orders.where(status: key).count %>
            </span>
          <% end %>
        <% end %>
      </div>
    </div>
    <!-- Główny pasek narzędzi -->
    <div class="flex items-center gap-1.5 bg-base-100 rounded-t-lg shadow-sm px-2 py-4 border-b border-base-200">
      <!-- Select all -->
      <div class="dropdown dropdown-start" data-checkbox-select-all-target="parent">
        <label tabindex="0" class="btn btn-sm btn-ghost flex items-center gap-1.5">
          <%= lucide_icon('check-square', class: 'w-4 h-4') %>
          <span class="font-medium tabular-nums text-xs hidden" data-checkbox-select-all-target="counter">
            0 / <%= @orders.count %>
          </span>
          <%= lucide_icon('chevron-down', class: 'w-3 h-3 opacity-50') %>
        </label>
        <ul tabindex="0" class="dropdown-content menu p-1.5 shadow-lg bg-base-100 rounded-box w-48 border border-base-200">
          <li><a class="text-sm" data-action="click->checkbox-select-all#toggleChildren" data-value="true">Zaznacz wszystkie</a></li>
          <li><a class="text-sm" data-action="click->checkbox-select-all#toggleChildren" value="false">Odznacz wszystkie</a></li>
        </ul>
      </div>
      <!-- Bulk actions -->
      <div class="flex items-center gap-0.5">
        <!-- Zmień status zaznaczonych -->
        <div class="dropdown">
          <div tabindex="0" role="button" class="btn btn-sm btn-ghost" title="Zmień status">
            <%= lucide_icon('flag', class: 'w-4 h-4') %>
          </div>
          <ul tabindex="0" class="dropdown-content menu bg-base-100 rounded-lg z-1 w-52 p-1 shadow-lg border border-base-200">
            <% Order.statuses.each do |status, _| %>
              <li>
                <button
                  type="submit"
                  form="bulk_action_form"
                  formaction="<%= bulk_action_orders_path(action_type: 'update_status', new_status: status) %>"
                  class="text-sm"
                >
                  <%= Order::STATUS_NAMES[status.to_sym] %>
                </button>
              </li>
            <% end %>
          </ul>
        </div>
        <!-- Usuń zaznaczone -->
        <button
          type="submit"
          form="bulk_action_form"
          formaction="<%= bulk_action_orders_path(action_type: 'delete') %>"
          class="btn btn-sm btn-ghost text-error hover:text-error"
          onclick="return confirm('Czy na pewno chcesz usunąć zaznaczone zamówienia?')"
          title="Usuń zaznaczone"
        >
          <%= lucide_icon('trash-2', class: 'w-4 h-4') %>
        </button>
      </div>
      <!-- Pole wyszukiwania -->
      <div class="flex flex-1 justify-center min-w-0">
        <div class="relative w-full max-w-4xl">
          <span class="absolute left-2.5 top-1/2 -translate-y-1/2 pointer-events-none text-text-muted">
            <%= lucide_icon('search', class: 'w-3.5 h-3.5') %>
          </span>
          <%= f.search_field :customer_first_name_or_customer_last_name_cont,
              placeholder: "Szukaj po imieniu lub nazwisku klienta...",
              class: "input input-md input-bordered w-full pl-8 bg-transparent border-base-200 focus:border-primary" %>
        </div>
      </div>
      <!-- Filtry toggle -->
      <button
        type="button"
        data-action="click->collapse#toggle"
        class="btn btn-sm btn-ghost gap-1.5 shrink-0"
        >
        <%= lucide_icon('sliders-horizontal', class: 'w-3.5 h-3.5') %>
        <span class="hidden sm:inline text-xs">Filtry</span>
        <%= lucide_icon('chevron-down', class: 'w-3 h-3 opacity-50 transition-transform', data: { collapse_target: 'icon' }) %>
      </button>
    </div>
    <!-- Panel filtrów (zwijany) -->
    <div data-collapse-target="content" class="bg-base-100 shadow-sm px-4 py-3 border-b border-base-200">
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
        <div class="form-control">
          <%= f.label :shipping_method_cont, "Sposób wysyłki", class: "label label-text text-xs pb-1" %>
          <%= f.search_field :shipping_method_cont, placeholder: "Filtruj...", class: "input input-sm input-bordered w-full" %>
        </div>
        <div class="form-control">
          <%= f.label :payment_method_cont, "Sposób płatności", class: "label label-text text-xs pb-1" %>
          <%= f.search_field :payment_method_cont, placeholder: "Filtruj...", class: "input input-sm input-bordered w-full" %>
        </div>
        <div class="form-control">
          <%= f.label :shipping_cost_gteq, "Dostawa od", class: "label label-text text-xs pb-1" %>
          <%= f.number_field :shipping_cost_gteq, placeholder: "Min", step: "0.01", class: "input input-sm input-bordered w-full" %>
        </div>
        <div class="form-control">
          <%= f.label :shipping_cost_lteq, "Dostawa do", class: "label label-text text-xs pb-1" %>
          <%= f.number_field :shipping_cost_lteq, placeholder: "Max", step: "0.01", class: "input input-sm input-bordered w-full" %>
        </div>
        <div class="form-control">
          <%= f.label :total_amount_gteq, "Kwota od", class: "label label-text text-xs pb-1" %>
          <%= f.number_field :total_amount_gteq, placeholder: "Min", step: "0.01", class: "input input-sm input-bordered w-full" %>
        </div>
        <div class="form-control">
          <%= f.label :total_amount_lteq, "Kwota do", class: "label label-text text-xs pb-1" %>
          <%= f.number_field :total_amount_lteq, placeholder: "Max", step: "0.01", class: "input input-sm input-bordered w-full" %>
        </div>
        <div class="form-control">
          <%= f.label :order_items_name_cont, "Produkt", class: "label label-text text-xs pb-1" %>
          <%= f.search_field :order_items_name_cont, placeholder: "Nazwa produktu...", class: "input input-sm input-bordered w-full" %>
        </div>
      </div>
      <div class="flex justify-end gap-2 mt-4">
        <%= link_to "Wyczyść", orders_path(status: params[:status].presence), class: "btn btn-sm btn-ghost" %>
        <%= f.submit "Zastosuj filtry", class: "btn btn-sm btn-primary" %>
      </div>
    </div>
  <% end %>
  <!-- Formularz akcji zbiorczych -->
  <%= form_with url: bulk_action_orders_path, method: :patch, id: "bulk_action_form" do %>
  <% end %>
</div>
