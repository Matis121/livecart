<%= turbo_frame_tag "discount_code_section" do %>
  <h3 class="subsection-title mb-3">Kod rabatowy</h3>
  <%= form_with model: @order, url: update_discount_code_order_path(@order), method: :patch do |f| %>
    <div class="space-y-3">
      <div class="flex justify-between items-center">
        <span class="label-text">Kod</span>
        <%= f.text_field :discount_code, value: @order.discount_code&.code, class: "input input-bordered input-sm w-44", placeholder: "np. DISCOUNT10" %>
      </div>
    </div>
    <div class="flex justify-end gap-2 mt-4">
      <%= link_to "Anuluj", order_path(@order), class: "btn btn-ghost btn-sm" %>
      <%= f.submit "Zastosuj", class: "btn btn-primary btn-sm" %>
    </div>
  <% end %>
<% end %>
