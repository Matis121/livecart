<%= turbo_frame_tag "contact_info_section" do %>
  <h3 class="subsection-title mb-3">Dane kontaktowe</h3>
  <%= form_with model: @order, url: update_contact_info_order_path(@order), method: :patch do |f| %>
    <div class="space-y-3">
      <div class="flex justify-between items-center">
        <span class="label-text">Email</span>
        <%= f.email_field :email, class: "input input-bordered input-sm w-44", placeholder: "jan@example.com" %>
      </div>
      <div class="flex justify-between items-center">
        <span class="label-text">Telefon</span>
        <%= f.text_field :phone, class: "input input-bordered input-sm w-44", placeholder: "+48 123 456 789" %>
      </div>
    </div>
    <div class="flex justify-end gap-2 mt-4">
      <%= link_to "Anuluj", order_path(@order), class: "btn btn-ghost btn-sm" %>
      <%= f.submit "Zapisz", class: "btn btn-primary btn-sm" %>
    </div>
  <% end %>
<% end %>
