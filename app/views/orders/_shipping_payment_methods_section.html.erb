<turbo-frame id="shipping_payment_methods_section">
  <h3 class="subsection-title mb-3">Wysyłka</h3>
  <%= link_to edit_shipping_payment_methods_order_path(order), data: { turbo_frame: "shipping_payment_methods_section" }, class: "block space-y-3 -mx-2 px-2 py-1 rounded-lg hover:bg-base-200/50 cursor-pointer transition-colors" do %>
    <div class="flex justify-between items-center">
      <span class="label-text">Sposób wysyłki</span>
      <span class="body-text font-medium"><%= order.shipping_method.presence || "—" %></span>
    </div>
    <div class="flex justify-between items-center">
      <span class="label-text">Koszt wysyłki</span>
      <span class="body-text font-medium"><%= number_to_currency(order.shipping_cost, unit: order.currency) %></span>
    </div>
  <% end %>
</turbo-frame>
