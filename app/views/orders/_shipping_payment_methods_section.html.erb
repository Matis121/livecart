<turbo-frame id="shipping_payment_methods_section">
  <div class="flex justify-between items-start mb-3">
    <h3 class="subsection-title">Wysyłka i płatność</h3>
    <%= link_to edit_shipping_payment_methods_order_path(order),
        class: "btn btn-ghost btn-sm btn-square" do %>
      <%= lucide_icon "pencil", class: "w-4 h-4" %>
    <% end %>
  </div>
  <div class="space-y-3">
    <div class="flex justify-between items-center">
      <span class="label-text">Sposób płatności</span>
      <span class="body-text font-medium"><%= order.payment_method.presence || "—" %></span>
    </div>
    <div class="flex justify-between items-center">
      <span class="label-text">Sposób wysyłki</span>
      <span class="body-text font-medium"><%= order.shipping_method.presence || "—" %></span>
    </div>
    <div class="flex justify-between items-center">
      <span class="label-text">Koszt wysyłki</span>
      <span class="body-text font-medium"><%= number_to_currency(order.shipping_cost, unit: order.currency) %></span>
    </div>
  </div>
</turbo-frame>
