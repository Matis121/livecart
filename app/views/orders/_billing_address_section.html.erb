<turbo-frame id="billing_address_section">
  <div class="flex items-center gap-2 mb-3">
    <h3 class="subsection-title">Dane faktury</h3>
    <% if billing_address&.needs_invoice %>
      <span class="badge badge-info badge-sm whitespace-nowrap">Potrzebna faktura</span>
    <% end %>
  </div>
  <%= link_to edit_order_billing_address_path(order), data: { turbo_frame: "billing_address_section" }, class: "block -mx-2 px-2 py-1 rounded-lg hover:bg-base-200/50 cursor-pointer transition-colors mb-3" do %>
    <% if billing_address&.first_name.present? || billing_address&.company_name.present? || billing_address&.address_line1.present? %>
      <div class="space-y-0.5">
        <% if billing_address.company_name.present? %>
          <div class="body-text"><%= billing_address.company_name %></div>
        <% end %>
        <% if billing_address.nip.present? %>
          <div class="label-text">NIP: <%= billing_address.nip %></div>
        <% end %>
        <% if billing_address.first_name.present? || billing_address.last_name.present? %>
          <div class="<%= billing_address.company_name.present? ? 'body-secondary' : 'body-text' %>"><%= [billing_address.first_name, billing_address.last_name].compact.join(" ") %></div>
        <% end %>
        <% if billing_address.address_line1.present? %>
          <div class="label-text"><%= billing_address.address_line1 %></div>
        <% end %>
        <% if billing_address.address_line2.present? %>
          <div class="label-text"><%= billing_address.address_line2 %></div>
        <% end %>
        <% if billing_address.postal_code.present? || billing_address.city.present? %>
          <div class="label-text"><%= [billing_address.postal_code, billing_address.city].compact.join(" ") %></div>
        <% end %>
        <% if billing_address.country.present? %>
          <div class="label-text"><%= billing_address.country_name %></div>
        <% end %>
      </div>
    <% else %>
      <span class="label-text">Brak adresu</span>
    <% end %>
  <% end %>
  <%= button_to copy_from_shipping_order_billing_address_path(order),
      method: :patch,
      class: "btn btn-ghost btn-xs gap-1",
      data: {
        turbo_confirm: "Czy na pewno chcesz skopiować dane z adresu dostawy? Obecne dane zostaną nadpisane."
      } do %>
    <%= lucide_icon "copy", class: "w-3 h-3" %>
    Skopiuj z dostawy
  <% end %>
</turbo-frame>
