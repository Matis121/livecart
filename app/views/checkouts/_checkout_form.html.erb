<!-- Shop header bar -->
<div class="flex items-center gap-3 mb-8 pb-5 border-b border-base-300/60">
  <% if account_logo.present? %>
    <div class="w-10 h-10 rounded-xl overflow-hidden bg-base-100 border border-base-300 flex items-center justify-center shrink-0">
      <%= image_tag account_logo, alt: "logo", class: "w-full h-full object-contain p-1.5" %>
    </div>
  <% end %>
  <div class="min-w-0">
    <p class="tiny-text mb-0.5">Zakup w</p>
    <h4 class="subsection-title tracking-tight truncate"><%= account_name %></h4>
  </div>
  <div class="ml-auto flex items-center gap-1.5 shrink-0">
    <%= lucide_icon "lock", class: "w-3 h-3" %>
    <span class="caption-text hidden sm:inline">Bezpieczna płatność</span>
  </div>
</div>
<!-- Main grid -->
<div class="flex flex-col xl:flex-row gap-6 items-start">
  <!-- Left column: Form -->
  <div class="flex-1 min-w-0">
    <%= form_with model: order, url: checkout_path(order.account.slug, checkout.token), method: :patch, local: true, data: { controller: "checkout-form" } do |f| %>
      <div class="space-y-4">
        <!-- 1. Dane kontaktowe -->
        <div class="bg-base-100 rounded-lg border border-base-300/60 shadow-sm overflow-hidden">
          <div class="flex items-center gap-3 px-6 py-4 bg-base-200/40 border-b border-base-300/40">
            <h2 class="subsection-title tracking-tight">Dane kontaktowe</h2>
          </div>
          <div class="p-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="form-control">
                <%= f.label :email, "Email *", class: "label label-text font-medium" %>
                <%= f.email_field :email,
                  class: "input input-bordered w-full rounded-xl",
                  required: true,
                  placeholder: "twoj@email.pl" %>
              </div>
              <div class="form-control">
                <%= f.label :phone, "Telefon *", class: "label label-text font-medium" %>
                <%= f.telephone_field :phone,
                  class: "input input-bordered w-full rounded-xl",
                  required: true,
                  placeholder: "+48 123 456 789" %>
              </div>
            </div>
          </div>
        </div>
        <!-- 2. Adres dostawy -->
        <div class="bg-base-100 rounded-lg border border-base-300/60 shadow-sm overflow-hidden">
          <div class="flex items-center gap-3 px-6 py-4 bg-base-200/40 border-b border-base-300/40">
            <h2 class="subsection-title tracking-tight">Adres dostawy</h2>
          </div>
          <div class="p-6">
            <%= f.fields_for :shipping_address_attributes, order.shipping_address do |sa| %>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="form-control">
                  <%= sa.label :first_name, "Imię *", class: "label label-text font-medium" %>
                  <%= sa.text_field :first_name, class: "input input-bordered w-full rounded-xl", required: true %>
                </div>
                <div class="form-control">
                  <%= sa.label :last_name, "Nazwisko *", class: "label label-text font-medium" %>
                  <%= sa.text_field :last_name, class: "input input-bordered w-full rounded-xl", required: true %>
                </div>
                <div class="form-control md:col-span-2">
                  <%= sa.label :address_line1, "Ulica i numer *", class: "label label-text font-medium" %>
                  <%= sa.text_field :address_line1, class: "input input-bordered w-full rounded-xl", required: true, placeholder: "np. ul. Główna 123" %>
                </div>
                <div class="form-control md:col-span-2">
                  <%= sa.label :address_line2, "Dodatkowe informacje", class: "label label-text font-medium" %>
                  <%= sa.text_field :address_line2, class: "input input-bordered w-full rounded-xl", placeholder: "np. mieszkanie 4, kod domofonu" %>
                </div>
                <div class="form-control">
                  <%= sa.label :postal_code, "Kod pocztowy *", class: "label label-text font-medium" %>
                  <%= sa.text_field :postal_code, class: "input input-bordered w-full rounded-xl", required: true, placeholder: "00-000" %>
                </div>
                <div class="form-control">
                  <%= sa.label :city, "Miasto *", class: "label label-text font-medium" %>
                  <%= sa.text_field :city, class: "input input-bordered w-full rounded-xl", required: true %>
                </div>
                <div class="form-control md:col-span-2">
                  <%= sa.label :country, "Kraj *", class: "label label-text font-medium" %>
                  <%= sa.text_field :country, class: "input input-bordered w-full rounded-xl", required: true, value: order.shipping_address.country.presence || "Polska" %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
        <!-- 3. Dane do faktury -->
        <div class="bg-base-100 rounded-lg border border-base-300/60 shadow-sm overflow-hidden">
          <div class="flex items-center gap-3 px-6 py-4 bg-base-200/40 border-b border-base-300/40">
            <h2 class="subsection-title tracking-tight">Dane do faktury</h2>
          </div>
          <div class="p-6">
            <%= f.fields_for :billing_address_attributes, order.billing_address do |ba| %>
              <div class="form-control mb-4">
                <label class="label cursor-pointer justify-start gap-3 p-0">
                  <%= ba.check_box :needs_invoice,
                    class: "checkbox checkbox-primary",
                    onchange: "document.getElementById('invoice-fields').classList.toggle('hidden')" %>
                  <span class="label-text font-medium">Chcę otrzymać fakturę VAT</span>
                </label>
              </div>
              <div id="invoice-fields" class="<%= 'hidden' unless order.billing_address.needs_invoice %> space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div class="form-control md:col-span-2">
                    <%= ba.label :company_name, "Nazwa firmy", class: "label label-text font-medium" %>
                    <%= ba.text_field :company_name, class: "input input-bordered w-full rounded-xl" %>
                  </div>
                  <div class="form-control">
                    <%= ba.label :nip, "NIP", class: "label label-text font-medium" %>
                    <%= ba.text_field :nip, class: "input input-bordered w-full rounded-xl", placeholder: "0000000000" %>
                  </div>
                  <div class="form-control">
                    <%= ba.label :first_name, "Imię", class: "label label-text font-medium" %>
                    <%= ba.text_field :first_name, class: "input input-bordered w-full rounded-xl" %>
                  </div>
                  <div class="form-control">
                    <%= ba.label :last_name, "Nazwisko", class: "label label-text font-medium" %>
                    <%= ba.text_field :last_name, class: "input input-bordered w-full rounded-xl" %>
                  </div>
                  <div class="form-control md:col-span-2">
                    <%= ba.label :address_line1, "Ulica i numer", class: "label label-text font-medium" %>
                    <%= ba.text_field :address_line1, class: "input input-bordered w-full rounded-xl" %>
                  </div>
                  <div class="form-control">
                    <%= ba.label :postal_code, "Kod pocztowy", class: "label label-text font-medium" %>
                    <%= ba.text_field :postal_code, class: "input input-bordered w-full rounded-xl", placeholder: "00-000" %>
                  </div>
                  <div class="form-control">
                    <%= ba.label :city, "Miasto", class: "label label-text font-medium" %>
                    <%= ba.text_field :city, class: "input input-bordered w-full rounded-xl" %>
                  </div>
                  <div class="form-control md:col-span-2">
                    <%= ba.label :country, "Kraj", class: "label label-text font-medium" %>
                    <%= ba.text_field :country, class: "input input-bordered w-full rounded-xl", value: "Polska" %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
        <!-- 4. Sposób realizacji (tylko przy open_package) -->
        <% if open_package_enabled %>
          <div class="bg-base-100 rounded-lg border border-base-300/60 shadow-sm overflow-hidden">
            <div class="flex items-center gap-3 px-6 py-4 bg-base-200/40 border-b border-base-300/40">
              <h2 class="subsection-title tracking-tight">Sposób realizacji</h2>
            </div>
            <div class="p-6">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <label class="relative flex flex-col p-5 border-2 border-base-300 rounded-xl cursor-pointer hover:border-warning/50 transition-all has-checked:border-warning has-checked:bg-warning/5" data-action="change->checkout-form#toggleMode">
                  <input type="radio" name="commit_type" value="open_package" class="radio radio-warning absolute top-4 right-4" data-checkout-form-target="modeRadio" />
                  <div class="flex items-center gap-3 mb-2 pr-8">
                    <%= lucide_icon "package-open", class: "w-5 h-5 text-warning shrink-0" %>
                    <span class="subsection-title">Otwarta paczka</span>
                  </div>
                  <p class="body-secondary">Zapisz dane i wróć później, aby zamknąć paczkę i zapłacić.</p>
                </label>
                <label class="relative flex flex-col p-5 border-2 border-base-300 rounded-xl cursor-pointer hover:border-primary/50 transition-all has-checked:border-primary has-checked:bg-primary/5" data-action="change->checkout-form#toggleMode">
                  <input type="radio" name="commit_type" value="ship_now" class="radio radio-primary absolute top-4 right-4" data-checkout-form-target="modeRadio" />
                  <div class="flex items-center gap-3 mb-2 pr-8">
                    <%= lucide_icon "send", class: "w-5 h-5 text-primary shrink-0" %>
                    <span class="subsection-title">Wyślij teraz</span>
                  </div>
                  <p class="body-secondary">Wybierz dostawę, płatność i złóż zamówienie od razu.</p>
                </label>
              </div>
            </div>
          </div>
        <% else %>
          <input type="hidden" name="commit_type" value="ship_now" />
        <% end %>
        <!-- Dostawa i płatność (widoczne przy "Wyślij teraz") -->
        <div id="shipping-payment-section" class="<%= 'hidden' if open_package_enabled %> space-y-4" data-checkout-form-target="paymentSection">
          <!-- Metoda dostawy -->
          <div class="bg-base-100 rounded-lg border border-base-300/60 shadow-sm overflow-hidden">
            <div class="flex items-center gap-3 px-6 py-4 bg-base-200/40 border-b border-base-300/40">
              <%= lucide_icon "truck", class: "w-4 h-4 text-base-content/50" %>
              <h2 class="subsection-title tracking-tight">Metoda dostawy</h2>
            </div>
            <div class="px-6 py-4 space-y-2">
              <% shipping_methods.each_with_index do |method, index| %>
                <label class="flex items-center justify-between gap-4 p-4 border border-base-200 rounded-xl cursor-pointer hover:bg-base-200/30 hover:border-primary/30 transition-colors has-checked:border-primary has-checked:bg-primary/5">
                  <div class="flex items-center gap-3">
                    <%= f.radio_button :shipping_method_id, method.id, class: "radio radio-primary shrink-0", data: { checkout_form_target: "shippingRadio" } %>
                    <span class="body-text font-medium"><%= method.name %></span>
                  </div>
                  <span class="body-secondary shrink-0">
                    <%= method.free_above.present? ? "Darmowa od #{number_to_currency(method.free_above)}" : number_to_currency(method.price) %>
                  </span>
                </label>
              <% end %>
            </div>
          </div>
          <!-- Metoda płatności -->
          <div class="bg-base-100 rounded-lg border border-base-300/60 shadow-sm overflow-hidden">
            <div class="flex items-center gap-3 px-6 py-4 bg-base-200/40 border-b border-base-300/40">
              <%= lucide_icon "credit-card", class: "w-4 h-4 text-base-content/50" %>
              <h2 class="subsection-title tracking-tight">Metoda płatności</h2>
            </div>
            <div class="px-6 py-4 space-y-2">
              <% payment_methods.each do |method| %>
                <label class="flex items-center gap-3 p-4 border border-base-200 rounded-xl cursor-pointer hover:bg-base-200/30 hover:border-primary/30 transition-colors has-checked:border-primary has-checked:bg-primary/5">
                  <%= f.radio_button :payment_method, method.name, class: "radio radio-primary shrink-0", data: { checkout_form_target: "paymentRadio" } %>
                  <div>
                    <span class="body-text font-medium"><%= method.name %></span>
                    <% if method.description.present? %>
                      <p class="caption-text mt-0.5"><%= method.description %></p>
                    <% end %>
                  </div>
                </label>
              <% end %>
            </div>
          </div>
        </div>
        <!-- Regulamin + Submit -->
        <div class="bg-base-100 rounded-lg border border-base-300/60 shadow-sm p-6">
          <div class="form-control mb-5">
            <label class="label cursor-pointer justify-start gap-3 p-0">
              <input type="checkbox" class="checkbox checkbox-primary" required />
              <span class="label-text">Akceptuję regulamin i politykę prywatności *</span>
            </label>
          </div>
          <div data-checkout-form-target="submitArea">
            <button type="submit" class="btn btn-primary btn-lg w-full rounded-xl font-semibold btn-disabled" disabled data-checkout-form-target="submitButton">
              Wybierz sposób realizacji
            </button>
          </div>
        </div>
      </div>
    <% end %>
  </div>
  <!-- Right column: Summary (sticky on desktop, top on mobile) -->
  <div class="w-full xl:w-105 shrink-0 order-first xl:order-last">
    <div class="xl:sticky xl:top-6">
      <%= render partial: "checkouts/order_summary", locals: { order: order } %>
    </div>
  </div>
</div>
