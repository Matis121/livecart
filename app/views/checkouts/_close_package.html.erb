<!-- Header -->
<div class="flex items-center gap-4 mb-8 pb-5 border-b border-base-300/60">
  <div class="inline-flex items-center justify-center w-10 h-10 rounded-xl bg-warning/10">
    <%= lucide_icon "package-open", class: "w-5 h-5 text-warning" %>
  </div>
  <div>
    <h1 class="page-title tracking-tight leading-tight">Otwarta paczka</h1>
    <p class="body-secondary">Zamknij paczkę, aby sfinalizować zamówienie.</p>
  </div>
</div>

<div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
  <!-- Lewa kolumna: Formularz zamknięcia -->
  <div class="xl:col-span-2 space-y-4">

    <!-- Adres dostawy (podgląd) -->
    <div class="bg-base-100 rounded-2xl border border-base-300/60 shadow-sm overflow-hidden">
      <div class="flex items-center gap-3 px-6 py-4 bg-base-200/40 border-b border-base-300/40">
        <%= lucide_icon "map-pin", class: "w-4 h-4 text-base-content/50" %>
        <h2 class="subsection-title tracking-tight">Adres dostawy</h2>
      </div>
      <div class="p-6">
        <div class="bg-base-200/40 rounded-xl p-4 space-y-0.5">
          <p class="body-text font-semibold"><%= order.shipping_address.first_name %> <%= order.shipping_address.last_name %></p>
          <p class="body-secondary"><%= order.shipping_address.address_line1 %></p>
          <% if order.shipping_address.address_line2.present? %>
            <p class="body-secondary"><%= order.shipping_address.address_line2 %></p>
          <% end %>
          <p class="body-secondary"><%= order.shipping_address.postal_code %> <%= order.shipping_address.city %></p>
        </div>
      </div>
    </div>

    <%= form_with url: close_package_checkout_path(order.account.slug, checkout.token), method: :patch, local: true do |f| %>
      <!-- Metoda dostawy -->
      <div class="bg-base-100 rounded-2xl border border-base-300/60 shadow-sm overflow-hidden">
        <div class="flex items-center gap-3 px-6 py-4 bg-base-200/40 border-b border-base-300/40">
          <%= lucide_icon "truck", class: "w-4 h-4 text-base-content/50" %>
          <h2 class="subsection-title tracking-tight">Metoda dostawy</h2>
        </div>
        <div class="px-6 py-4 space-y-2">
          <% order.account.shipping_methods.active.order(:position).each_with_index do |method, index| %>
            <label class="flex items-center justify-between gap-4 p-4 border border-base-200 rounded-xl cursor-pointer hover:bg-base-200/30 hover:border-primary/30 transition-colors has-checked:border-primary has-checked:bg-primary/5">
              <div class="flex items-center gap-3">
                <%= f.radio_button "order[shipping_method_id]", method.id, class: "radio radio-primary shrink-0", required: index == 0 %>
                <span class="body-text font-medium"><%= method.name %></span>
              </div>
              <span class="body-secondary shrink-0">
                <%= method.free_above.present? ? "Darmowa od #{number_to_currency(method.free_above)}" : number_to_currency(method.price) %>
              </span>
            </label>
          <% end %>
        </div>
      </div>

      <!-- Metoda płatności -->
      <div class="bg-base-100 rounded-2xl border border-base-300/60 shadow-sm overflow-hidden mt-4">
        <div class="flex items-center gap-3 px-6 py-4 bg-base-200/40 border-b border-base-300/40">
          <%= lucide_icon "credit-card", class: "w-4 h-4 text-base-content/50" %>
          <h2 class="subsection-title tracking-tight">Metoda płatności</h2>
        </div>
        <div class="px-6 py-4 space-y-2">
          <% @payment_methods.each_with_index do |method, index| %>
            <label class="flex items-center gap-3 p-4 border border-base-200 rounded-xl cursor-pointer hover:bg-base-200/30 hover:border-primary/30 transition-colors has-checked:border-primary has-checked:bg-primary/5">
              <%= f.radio_button "order[payment_method]", method.name, class: "radio radio-primary shrink-0", required: index == 0 %>
              <div>
                <span class="body-text font-medium"><%= method.name %></span>
                <% if method.description.present? %>
                  <p class="caption-text mt-0.5"><%= method.description %></p>
                <% end %>
              </div>
            </label>
          <% end %>
        </div>
      </div>

      <!-- Submit -->
      <div class="bg-base-100 rounded-2xl border border-base-300/60 shadow-sm p-6 mt-4">
        <button type="submit" class="btn btn-primary btn-lg w-full rounded-xl font-semibold">
          <%= lucide_icon "package-check", class: "w-5 h-5" %>
          Zamknij paczkę i zamów
        </button>
      </div>
    <% end %>
  </div>

  <!-- Prawa kolumna: Podsumowanie -->
  <div class="xl:col-span-1 order-first xl:order-last">
    <div class="xl:sticky xl:top-6">
      <%= render partial: "checkouts/order_summary", locals: { order: order } %>
    </div>
  </div>
</div>
