<div class="bg-base-100 rounded-lg border border-base-300/60 shadow-sm overflow-hidden">
  <div class="px-6 py-4 bg-base-200/40 border-b border-base-300/40">
    <h2 class="subsection-title tracking-tight">Twoje zamówienie</h2>
  </div>
  <% if order.order_items.any? %>
    <!-- Lista produktów -->
    <div class="p-6 space-y-4">
      <% order.order_items.includes(:product).each do |item| %>
        <div class="flex gap-3">
          <div class="relative shrink-0">
            <div class="w-16 h-16 rounded-xl bg-base-200 overflow-hidden border border-base-300/60">
              <% if item.product&.images&.attached? %>
                <%= image_tag item.product.images.first.variant(:thumb), class: "object-cover w-full h-full" %>
              <% else %>
                <div class="w-full h-full flex items-center justify-center">
                  <%= lucide_icon "image", class: "w-6 h-6 text-base-content/20" %>
                </div>
              <% end %>
            </div>
          </div>
          <div class="flex-1 min-w-0 flex flex-col justify-center gap-0.5">
            <p class="body-text font-medium leading-snug line-clamp-2"><%= item.product&.name || "Produkt" %></p>
            <p class="caption-text text-base-content/50">
              <%= item.quantity %> szt. &times; <%= number_to_currency(item.unit_price) %>
            </p>
            <p class="body-text font-semibold text-base-content/80">
              <%= number_to_currency(item.total_price) %>
            </p>
          </div>
        </div>
      <% end %>
    </div>
    <div class="border-t border-base-200 mx-6"></div>
    <!-- Koszty -->
    <div class="px-6 py-4 space-y-2">
      <div class="flex justify-between">
        <span class="body-secondary">Produkty</span>
        <span class="body-text font-medium"><%= number_to_currency(order.order_items.sum(&:total_price)) %></span>
      </div>
      <div class="flex justify-between">
        <span class="body-secondary">Dostawa</span>
        <% if order.shipping_cost > 0 %>
          <span class="body-text font-medium"><%= number_to_currency(order.shipping_cost) %></span>
        <% else %>
          <span class="body-text font-medium text-success">Darmowa</span>
        <% end %>
      </div>
    </div>
    <div class="border-t border-base-200 mx-6"></div>
    <!-- Suma końcowa -->
    <div class="px-6 py-5 flex justify-between items-center">
      <span class="subsection-title">Do zapłaty</span>
      <span class="text-2xl font-bold tracking-tight">
        <%= number_to_currency(order.total_amount) %>
      </span>
    </div>
    <!-- Stopka bezpieczeństwa -->
    <div class="bg-base-200/40 border-t border-base-200 px-6 py-3 flex items-center gap-2">
      <%= lucide_icon "shield-check", class: "w-4 h-4 text-success shrink-0" %>
      <p class="caption-text">Twoje dane są bezpieczne. Płatność szyfrowana.</p>
    </div>
  <% else %>
    <div class="p-12 text-center">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-base-200 mb-3">
        <%= lucide_icon "shopping-bag", class: "w-6 h-6 text-base-content/30" %>
      </div>
      <p class="body-secondary">Brak produktów w koszyku</p>
    </div>
  <% end %>
</div>
