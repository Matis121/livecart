<%= form_with model: @product, local: true, html: { multipart: true } do |f| %>
  <%# ===== NAGŁÓWEK Z AKCJAMI ===== %>
  <div class="<%= header_class("mb-8") %>">
    <%= render "shared/page_header",
        title: @product.persisted? ? "Edytuj produkt" : "Nowy produkt",
        back_path: products_path,
        back_label: "Powrót do produktów" %>
    <div class="flex items-center gap-2">
      <%= link_to "Anuluj", products_path, class: "btn btn-ghost" %>
      <%= f.submit @product.persisted? ? "Zapisz zmiany" : "Dodaj produkt", class: "btn btn-primary" %>
    </div>
  </div>
  <%# ===== DWUKOLUMNOWY GRID ===== %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <%# ===== LEWA KOLUMNA (główna treść) ===== %>
    <div class="lg:col-span-2 space-y-6">
      <%# KARTA: Informacje podstawowe %>
      <div class="bg-base-100 border border-base-200 rounded-xl p-6">
        <div class="flex items-center gap-2 mb-5">
          <%= lucide_icon("tag", class: "w-4 h-4 text-base-content/40") %>
          <h3 class="section-title">Informacje podstawowe</h3>
        </div>
        <div class="space-y-4">
          <div class="form-control w-full">
            <label class="label pb-1.5">
              <span class="label-text">Nazwa produktu</span>
            </label>
            <%= f.text_field :name, class: "input input-bordered w-full focus:input-primary", placeholder: "np. Koszulka męska" %>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="form-control w-full">
              <label class="label pb-1.5">
                <span class="label-text">SKU</span>
              </label>
              <%= f.text_field :sku, class: "input input-bordered w-full focus:input-primary font-mono", placeholder: "np. KOSZ-001" %>
            </div>
            <div class="form-control w-full">
              <label class="label pb-1.5">
                <span class="label-text">EAN</span>
              </label>
              <%= f.text_field :ean, class: "input input-bordered w-full focus:input-primary font-mono", placeholder: "np. 5901234123457" %>
            </div>
          </div>
        </div>
      </div>
      <%# KARTA: Zdjęcia %>
      <div class="bg-base-100 border border-base-200 rounded-xl p-6" data-controller="image-preview">
        <div class="flex items-center gap-2 mb-4">
          <%= lucide_icon("image", class: "w-4 h-4 text-base-content/40") %>
          <h3 class="section-title">Zdjęcia</h3>
        </div>
        <% if @product.images.attached? %>
          <p class="caption-text mb-3">Kliknij zdjęcie aby zaznaczyć je do usunięcia</p>
        <% end %>
        <%# Grid: istniejące zdjęcia + podgląd nowych + kafelek dodawania %>
        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-3">
          <% @product.images.each do |image| %>
            <div class="relative group">
              <%= check_box_tag "product[images_to_delete][]", image.id, false,
                  class: "peer sr-only",
                  id: "del_#{image.id}" %>
              <%= image_tag image, class: "w-full aspect-square object-cover rounded-lg border border-base-200 peer-checked:opacity-50 peer-checked:ring-2 peer-checked:ring-error/80 transition-all" %>
              <label for="del_<%= image.id %>"
                     class="absolute inset-0 flex flex-col items-center justify-center gap-1 rounded-lg cursor-pointer text-white transition-opacity opacity-0 group-hover:opacity-100 peer-checked:opacity-100 bg-error/70">
                <%= lucide_icon("trash-2", class: "w-4 h-4") %>
                <span class="tiny-text text-white">Usuń</span>
              </label>
            </div>
          <% end %>
          <%# Kafelek "Dodaj zdjęcia" — wbudowany w grid, input nakładka opacity-0 %>
          <label data-image-preview-target="uploadTile"
                 class="aspect-square border-2 border-dashed border-base-300 rounded-lg flex flex-col items-center justify-center gap-1.5 cursor-pointer hover:border-primary/50 hover:bg-primary/5 transition-colors group relative overflow-hidden">
            <%= lucide_icon("plus", class: "w-5 h-5 text-base-content/40 group-hover:text-primary transition-colors") %>
            <span class="tiny-text group-hover:text-primary transition-colors">Dodaj</span>
            <%= f.file_field :images, multiple: true, accept: "image/png,image/jpeg",
                class: "absolute inset-0 opacity-0 cursor-pointer w-full h-full",
                data: { "image-preview-target": "input", action: "change->image-preview#preview" } %>
          </label>
        </div>
      </div>
    </div>
    <%# ===== PRAWA KOLUMNA (sidebar) ===== %>
    <div class="space-y-6">
      <%# KARTA: Cena %>
      <div class="bg-base-100 border border-base-200 rounded-xl p-6">
        <div class="flex items-center gap-2 mb-5">
          <%= lucide_icon("circle-dollar-sign", class: "w-4 h-4 text-base-content/40") %>
          <h3 class="section-title">Cena</h3>
        </div>
        <div class="space-y-4">
          <div class="form-control w-full">
            <label class="label pb-1.5">
              <span class="label-text">Cena brutto</span>
            </label>
            <div class="relative">
              <%= f.number_field :gross_price, class: "input input-bordered w-full focus:input-primary pr-14", step: 0.01, min: 0, placeholder: "0.00" %>
              <span class="absolute right-3 top-1/2 -translate-y-1/2 caption-text font-mono">PLN</span>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div class="form-control w-full">
              <label class="label pb-1.5">
                <span class="label-text">VAT</span>
              </label>
              <%= f.select :tax_rate, [["23%", 23], ["8%", 8], ["5%", 5], ["0%", 0]], {}, class: "select select-bordered w-full focus:select-primary" %>
            </div>
            <div class="form-control w-full">
              <label class="label pb-1.5">
                <span class="label-text">Waluta</span>
              </label>
              <%= f.select :currency, [["PLN", "PLN"], ["EUR", "EUR"], ["USD", "USD"]], {}, class: "select select-bordered w-full focus:select-primary" %>
            </div>
          </div>
        </div>
      </div>
      <%# KARTA: Magazyn %>
      <div class="bg-base-100 border border-base-200 rounded-xl p-6">
        <div class="flex items-center gap-2 mb-5">
          <%= lucide_icon("warehouse", class: "w-4 h-4 text-base-content/40") %>
          <h3 class="section-title">Magazyn</h3>
        </div>
        <%= f.fields_for :product_stock do |stock_fields| %>
          <div class="form-control w-full">
            <label class="label pb-1.5">
              <span class="label-text">Stan magazynowy</span>
            </label>
            <div class="relative">
              <%= stock_fields.number_field :quantity, class: "input input-bordered w-full focus:input-primary pr-10", placeholder: "0" %>
              <span class="absolute right-3 top-1/2 -translate-y-1/2 caption-text">szt.</span>
            </div>
          </div>
        <% end %>
      </div>
      <%# KARTA: Integracje %>
      <div class="bg-base-100 border border-base-200 rounded-xl p-6">
        <div class="flex items-center gap-2 mb-5">
          <%= lucide_icon("blocks", class: "w-4 h-4 text-base-content/40") %>
          <h3 class="section-title">Integracje</h3>
        </div>
        <div class="flex gap-2.5 bg-info/10 border border-info/20 rounded-lg p-3 mb-4">
          <%= lucide_icon("info", class: "w-4 h-4 text-info shrink-0 mt-0.5") %>
          <p class="caption-text" style="color: oklch(from var(--color-info) calc(l * 0.8) c h)">
            Powiązanie z Baselinker umożliwia automatyczną synchronizację stanów magazynowych przy eksporcie zamówień.
          </p>
        </div>
        <div class="form-control w-full">
          <label class="label pb-1.5">
            <span class="label-text">Baselinker &mdash; ID produktu</span>
          </label>
          <%= f.text_field :baselinker_product_id,
              class: "input input-bordered w-full focus:input-primary font-mono text-sm",
              placeholder: "np. 12345" %>
        </div>
      </div>
    </div>
  </div>
<% end %>
