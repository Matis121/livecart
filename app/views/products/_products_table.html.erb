<div>
  <table class="table">
    <thead>
      <tr>
        <th class="label-text w-4">
        </th>
        <th class="label-text">Produkt</th>
        <th class="label-text w-32">Cena brutto</th>
        <th class="label-text w-24">VAT</th>
        <th class="label-text w-32">Stan</th>
        <th class="text-end label-text w-24">Akcje</th>
      </tr>
    </thead>
    <tbody>
      <% if @products.any? %>
        <% @products.each do |product| %>
          <tr>
            <td class="align-top">
              <%= check_box_tag "product_ids[]", product.id, nil, {
                multiple: true,
                form: "bulk_action_form",
                data: { checkbox_select_all_target: "child", action: "click->checkbox-select-all#toggleParent" }
              } %>
            </td>
            <td>
              <div class="flex items-center gap-3">
                <% unless cookies[:products_per_page].to_i > 50 %>
                  <div>
                    <% if product.images.attached? %>
                      <%= image_tag product.images.first.variant(:thumb), class: "w-14 h-14 object-cover rounded", loading: :lazy %>
                    <% else %>
                      <span class="text-text-muted"><%= lucide_icon('image', class: 'w-14 h-14') %></span>
                    <% end %>
                  </div>
                <% end %>
                <div>
                  <div class="font-medium">
                    <div class="mb-1">
                      <%= link_to product.name, edit_product_path(product), class: "hover:underline" %>
                    </div>
                    <div class="caption-text flex gap-3 font-normal">
                      <span class="flex items-center gap-1">
                        <span class="label-text font-semibold">ID:</span>
                        <%= product.id.presence || '-' %>
                      </span>
                      <span class="flex items-center gap-1">
                        <span class="label-text font-semibold">EAN:</span>
                        <%= product.ean.presence || '-' %>
                      </span>
                      <span class="flex items-center gap-1">
                        <span class="label-text font-semibold">SKU:</span>
                        <%= product.sku.presence || '-' %>
                      </span>
                    </div>
                  </div>
                </div>
              </div>
            </td>
            <td>
              <%= number_to_currency(product.gross_price, unit: product.currency) %>
            </td>
            <td>
              <%= product.tax_rate %>%
            </td>
            <td>
              <div class="flex items-center gap-2">
                <div>
                  <%= product.quantity %>
                </div>
              </div>
            </td>
            <td class="text-end">
              <div class="dropdown dropdown-end">
                <div tabindex="0" role="button" class="btn btn-sm btn-ghost">
                  <%= lucide_icon('more-vertical', class: 'w-4 h-4') %>
                </div>
                <ul tabindex="0" class="dropdown-content menu bg-base-100 rounded-box z-[1] w-52 p-2 shadow">
                  <li>
                    <%= link_to edit_product_path(product) do %>
                      <%= lucide_icon('edit', class: 'w-4 h-4') %>
                      Edytuj
                    <% end %>
                  </li>
                  <li>
                    <a onclick="history_modal_<%= product.id %>.showModal()">
                      <%= lucide_icon('history', class: 'w-4 h-4') %>
                      Historia produktu
                    </a>
                  </li>
                  <li>
                    <%= link_to product_path(product), data: { turbo_method: :delete, turbo_confirm: "Na pewno usunąć ten produkt?" }, class: "text-error" do %>
                      <%= lucide_icon('trash-2', class: 'w-4 h-4') %>
                      Usuń
                    <% end %>
                  </li>
                </ul>
              </div>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="8" class="text-center py-8">
            <%= render "products/empty_state" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <div class="flex items-center justify-end gap-4 px-4 py-3 border-t border-base-200">
    <div class="flex items-center gap-2">
      <select
        onchange="window.location.href = this.value"
        class="select select-sm select-bordered bg-base-100 min-h-0 h-8 pr-8"
      >
        <% @per_page_options.each do |option| %>
          <option
            value="<%= products_path(request.params.merge(per_page: option, page: 1)) %>"
            <%= 'selected' if @pagy.limit == option %>
          >
            <%= option %>
          </option>
        <% end %>
      </select>
    </div>
    <div class="flex items-center gap-1">
      <% if @pagy.page > 1 %>
        <%= link_to products_path(request.params.merge(page: @pagy.page - 1)), class: "p-1 rounded hover:bg-base-200 transition-colors" do %>
          <%= lucide_icon('chevron-left', class: 'w-4 h-4') %>
        <% end %>
      <% else %>
        <span class="p-1 opacity-30"><%= lucide_icon('chevron-left', class: 'w-4 h-4') %></span>
      <% end %>
      <span class="px-2 tabular-nums"><%= @pagy.page %> / <%= @pagy.pages %></span>
      <% if @pagy.page < @pagy.pages %>
        <%= link_to products_path(request.params.merge(page: @pagy.page + 1)), class: "p-1 rounded hover:bg-base-200 transition-colors" do %>
          <%= lucide_icon('chevron-right', class: 'w-4 h-4') %>
        <% end %>
      <% else %>
        <span class="p-1 opacity-30"><%= lucide_icon('chevron-right', class: 'w-4 h-4') %></span>
      <% end %>
    </div>
  </div>
</div>
