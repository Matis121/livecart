<div class="<%= header_class %>">
  <%= render "shared/page_header", title: "Importuj produkty z CSV", subtitle: "Dodaj produkty hurtowo z pliku CSV" %>
</div>
<% csv_help_content = capture do %>
  <div class="flex flex-wrap gap-3 mb-5">
    <div class="flex items-center gap-2 bg-primary/10 text-primary rounded-md px-3 py-1.5">
      <span class="text-xs font-semibold">Wymagane: <span class="font-mono">name, gross_price</span></span>
    </div>
    <div class="flex items-center gap-2 bg-base-200 rounded-md px-3 py-1.5">
      <span class="text-xs font-medium text-text-secondary">Opcjonalne: <span class="font-mono">sku, ean, tax_rate, currency, stock_quantity, image_urls, baselinker_product_id</span></span>
    </div>
  </div>
  <span class="caption-text mb-1.5 block">Przykład</span>
  <pre class="text-xs bg-base-200 p-4 rounded-lg overflow-x-auto leading-relaxed font-mono mb-4">sku,ean,name,gross_price,tax_rate,currency,stock_quantity,image_urls,baselinker_product_id
PROD-001,5901234123457,Koszulka męska,99.99,23,PLN,50,https://example.com/img1.jpg,12345
PROD-002,5901234123464,Spodnie damskie,149.99,23,PLN,30,https://example.com/img2.jpg,12346</pre>
  <p class="caption-text flex items-start gap-1.5">
    <%= lucide_icon('info', class: 'w-3.5 h-3.5 shrink-0 mt-px') %>
    Kolumna <span class="font-mono">baselinker_product_id</span> służy do powiązania produktów z katalogiem Baselinker. Magazyn wybierasz w konfiguracji integracji.
  </p>
<% end %>
<%= render "shared/help_section", title: "Format pliku CSV", storage_key: "import-csv-help", content: csv_help_content %>
<%= form_with url: import_products_path, method: :post, local: true, html: { multipart: true, class: "space-y-6" } do |f| %>
  <%# ===== SEKCJA: STRATEGIA DUPLIKATÓW ===== %>
  <section class="card bg-base-100 shadow-sm">
    <div class="card-body flex flex-col gap-6">
      <div class="flex flex-col gap-3">
        <h3 class="section-title">1. Wybierz plik CSV</h3>
        <div class="form-control w-full">
          <%= file_field_tag :csv_file, accept: ".csv", class: "file-input file-input-bordered w-full focus:file-input-primary", required: true %>
          <label class="label">
            <span class="caption-text">Tylko pliki .csv</span>
          </label>
        </div>
      </div>
      <div class="flex flex-col gap-3">
        <h3 class="section-title">2. Wybierz strategię obsługi duplikatów</h3>
        <div class="form-control">
          <label class="label cursor-pointer justify-start gap-4">
            <%= radio_button_tag :duplicate_strategy, "import_all", true, class: "radio radio-primary" %>
            <div>
              <span class="subsection-title">Importuj wszystko jako nowe produkty</span>
              <p class="body-secondary">Wszystkie wiersze z CSV zostaną dodane jako nowe produkty</p>
            </div>
          </label>
        </div>
        <div class="divider my-0"></div>
        <div class="form-control">
          <label class="label cursor-pointer justify-start gap-4">
            <%= radio_button_tag :duplicate_strategy, "skip_duplicate_sku", false, class: "radio radio-primary" %>
            <div>
              <span class="subsection-title">Pomiń produkty z istniejącym SKU</span>
              <p class="body-secondary">Jeśli SKU z CSV już istnieje w bazie, wiersz zostanie pominięty</p>
            </div>
          </label>
        </div>
        <div class="divider my-0"></div>
        <div class="form-control">
          <label class="label cursor-pointer justify-start gap-4">
            <%= radio_button_tag :duplicate_strategy, "skip_duplicate_ean", false, class: "radio radio-primary" %>
            <div>
              <span class="subsection-title">Pomiń produkty z istniejącym EAN</span>
              <p class="body-secondary">Jeśli EAN z CSV już istnieje w bazie, wiersz zostanie pominięty</p>
            </div>
          </label>
        </div>
        <div class="divider my-0"></div>
        <div class="form-control">
          <label class="label cursor-pointer justify-start gap-4">
            <%= radio_button_tag :duplicate_strategy, "skip_duplicate_name", false, class: "radio radio-primary" %>
            <div>
              <span class="subsection-title">Pomiń produkty z istniejącą nazwą</span>
              <p class="body-secondary">Jeśli nazwa produktu z CSV już istnieje w bazie, wiersz zostanie pominięty</p>
            </div>
          </label>
        </div>
      </div>
    </div>
  </section>
  <%# ===== PRZYCISKI ===== %>
  <div class="flex gap-2 justify-end">
    <%= f.submit "Importuj produkty", class: "btn btn-primary", data: { turbo: false } %>
  </div>
<% end %>
