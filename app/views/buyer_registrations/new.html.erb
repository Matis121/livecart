<% if params[:registered].present? %>
  <div class="min-h-[80vh] flex items-center justify-center px-4 py-16">
    <div class="text-center max-w-sm">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-success/10 mb-6">
        <%= lucide_icon "check", class: "w-10 h-10 text-success stroke-[2]" %>
      </div>
      <h1 class="page-title mb-3 tracking-tight">Gotowe!</h1>
      <p class="body-secondary mb-2">
        Twoje dane zostały zapisane w sklepie <strong><%= @shop.company_name %></strong>.
      </p>
      <p class="body-secondary mb-6">
        Po transmisji sprzedawca wyśle Ci link do zamówienia na podany email lub telefon.
      </p>
      <p class="text-xs text-base-content/40 mb-1">Zarejestrowany nick</p>
      <p class="font-medium text-base-content/70 bg-base-100 rounded-xl px-4 py-2 inline-block border border-base-300 font-mono">
        @<%= params[:registered] %>
      </p>
    </div>
  </div>
<% else %>
  <div class="container mx-auto px-4 py-8 max-w-lg">
    <!-- Nagłówek sklepu -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-primary/10 text-primary font-bold text-xl mb-4">
        <%= @shop.company_name.first.upcase %>
      </div>
      <h1 class="page-title tracking-tight mb-1"><%= @shop.company_name %></h1>
      <p class="text-sm text-base-content/40 mb-4">sklep live</p>
      <div class="w-full h-px bg-base-200 mb-6"></div>
      <p class="body-secondary">
        Podaj swój nick TikTok i dane kontaktowe. <br/>Po transmisji wyślemy Ci link do zamówienia na email lub SMS.
      </p>
    </div>

    <div class="bg-base-100 rounded-xl border border-base-300/60 shadow-sm overflow-hidden">
      <%= form_with url: buyer_registration_path(shop_slug: @shop.slug), method: :post, local: true, class: "p-6 space-y-4" do |f| %>
        <% nick_errors = @customer&.errors&.messages_for(:platform_username) || [] %>
        <div class="form-control">
          <label class="label label-text font-medium">Nick TikTok *</label>
          <div class="input input-bordered flex items-center gap-2 w-full <%= 'input-error' if nick_errors.any? %>">
            <span class="text-base-content/40 select-none">@</span>
            <input type="text"
                   name="tiktok_username"
                   class="grow bg-transparent outline-none"
                   placeholder="twój_nick"
                   value="<%= params[:tiktok_username].to_s.gsub('@', '') %>"
                   required
                   autocomplete="off"
                   maxlength="24"
                   oninput="this.value = this.value.replace(/[^a-zA-Z0-9._]/g, '').slice(0, 24)">
          </div>
          <% nick_errors.each do |msg| %>
            <p class="text-error text-sm mt-1"><%= msg %></p>
          <% end %>
        </div>

        <% email_errors = @customer&.errors&.messages_for(:email) || [] %>
        <div class="form-control">
          <label class="label label-text font-medium">Email *</label>
          <input type="email"
                 name="email"
                 class="input input-bordered w-full <%= 'input-error' if email_errors.any? %>"
                 placeholder="twoj@email.pl"
                 value="<%= params[:email] %>"
                 required>
          <% email_errors.each do |msg| %>
            <p class="text-error text-sm mt-1"><%= msg %></p>
          <% end %>
        </div>

        <% phone_errors = @customer&.errors&.messages_for(:phone) || [] %>
        <div class="form-control">
          <label class="label label-text font-medium">Telefon</label>
          <div class="flex gap-2">
            <select name="phone_prefix" class="select select-bordered w-28 shrink-0 <%= 'select-error' if phone_errors.any? %>">
              <% [
                ["+48",  "PL +48"],
                ["+49",  "DE +49"],
                ["+43",  "AT +43"],
                ["+32",  "BE +32"],
                ["+45",  "DK +45"],
                ["+33",  "FR +33"],
                ["+30",  "GR +30"],
                ["+31",  "NL +31"],
                ["+353", "IE +353"],
                ["+39",  "IT +39"],
                ["+1",   "CA/US +1"],
                ["+47",  "NO +47"],
                ["+351", "PT +351"],
                ["+40",  "RO +40"],
                ["+421", "SK +421"],
                ["+386", "SI +386"],
                ["+34",  "ES +34"],
                ["+46",  "SE +46"],
                ["+41",  "CH +41"],
                ["+380", "UA +380"],
                ["+44",  "GB +44"],
                ["+420", "CZ +420"],
                ["+36",  "HU +36"],
              ].each do |value, label| %>
                <option value="<%= value %>" <%= "selected" if (params[:phone_prefix] || "+48") == value %>><%= label %></option>
              <% end %>
            </select>
            <input type="tel"
                   name="phone_number"
                   class="input input-bordered flex-1 <%= 'input-error' if phone_errors.any? %>"
                   placeholder="123456789"
                   value="<%= params[:phone_number] %>"
                   maxlength="9"
                   pattern="\d{9}"
                   oninput="this.value = this.value.replace(/\D/g, '').slice(0, 9)">
          </div>
          <% phone_errors.each do |msg| %>
            <p class="text-error text-sm mt-1"><%= msg %></p>
          <% end %>
        </div>

        <div class="pt-2">
          <button type="submit" class="btn btn-primary w-full">
            Wyślij dane
          </button>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
