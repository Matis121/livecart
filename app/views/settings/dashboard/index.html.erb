<div class="<%= header_class %>">
  <div>
    <h1 class="<%= page_header_class %>">Ustawienia</h1>
    <p class="<%= page_header_paragraph_class %>">Zarządzaj ustawieniami swojego sklepu</p>
  </div>
</div>
<!-- Settings Cards -->
<div class="mb-8">
  <h2 class="section-title mb-4">Ustawienia sklepu</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <!-- Ogólne -->
    <div class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow">
      <div class="card-body">
        <div class="flex items-start justify-between mb-3">
          <h3 class="subsection-title">Ogólne</h3>
          <%= lucide_icon('grid-3x3', class: 'w-5 h-5 text-primary') %>
        </div>
        <p class="body-secondary mb-4">
          Edytuj podstawowe informacje o sklepie takie jak nazwa, zdjęcie profilowe
        </p>
        <%= link_to edit_settings_checkout_path, class: "btn btn-sm btn-ghost w-full justify-start" do %>
          Przejdź
          <%= lucide_icon('chevron-right', class: 'w-4 h-4 ml-auto') %>
        <% end %>
      </div>
    </div>
    <!-- Kody rabatowe -->
    <div class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow">
      <div class="card-body">
        <div class="flex items-start justify-between mb-3">
          <h3 class="subsection-title">Kody rabatowe</h3>
          <%= lucide_icon('percent', class: 'w-5 h-5 text-primary') %>
        </div>
        <p class="body-secondary mb-4">
          Uzupełnij kody rabatowe dla swojego sklepu
        </p>
        <%= link_to settings_discounts_path, class: "btn btn-sm btn-ghost w-full justify-start" do %>
          Przejdź
          <%= lucide_icon('chevron-right', class: 'w-4 h-4 ml-auto') %>
        <% end %>
      </div>
    </div>
    <!-- Regulamin -->
    <div class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow">
      <div class="card-body">
        <div class="flex items-start justify-between mb-3">
          <h3 class="subsection-title">Regulamin</h3>
          <%= lucide_icon('file-text', class: 'w-5 h-5 text-primary') %>
        </div>
        <p class="body-secondary mb-4">
          Uzupełnij regulamin i zasady kupowania w Twoim sklepie
        </p>
        <%= link_to edit_settings_terms_path, class: "btn btn-sm btn-ghost w-full justify-start" do %>
          Przejdź
          <%= lucide_icon('chevron-right', class: 'w-4 h-4 ml-auto') %>
        <% end %>
      </div>
    </div>
  </div>
</div>
<!-- Płatności i wysyłki (na razie puste) -->
<div>
  <h2 class="section-title mb-4">Płatności i wysyłki</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <div class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow">
      <div class="card-body">
        <div class="flex items-start justify-between mb-3">
          <h3 class="subsection-title">Wysyłki</h3>
          <%= lucide_icon('truck', class: 'w-5 h-5 text-primary') %>
        </div>
        <p class="body-secondary mb-4">
          Uzupełnij metody wysyłki dla swojego sklepu
        </p>
        <%= link_to settings_shipping_methods_path, class: "btn btn-sm btn-ghost w-full justify-start" do %>
          Przejdź
          <%= lucide_icon('chevron-right', class: 'w-4 h-4 ml-auto') %>
        <% end %>
      </div>
    </div>
    <div class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow">
      <div class="card-body">
        <div class="flex items-start justify-between mb-3">
          <h3 class="subsection-title">Płatności</h3>
          <%= lucide_icon('credit-card', class: 'w-5 h-5 text-primary') %>
        </div>
        <p class="body-secondary mb-4">
          Uzupełnij metody płatności dla swojego sklepu
        </p>
        <%= link_to settings_payment_methods_path, class: "btn btn-sm btn-ghost w-full justify-start" do %>
          Przejdź
          <%= lucide_icon('chevron-right', class: 'w-4 h-4 ml-auto') %>
        <% end %>
      </div>
    </div>
  </div>
</div>
