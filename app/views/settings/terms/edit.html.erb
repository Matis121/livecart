<div class="<%= header_class %>">
  <%= render "shared/page_header", title: "Regulamin i polityka prywatności", subtitle: "Edytuj treść regulaminu i polityki prywatności" %>
</div>
<%= form_with model: current_account, url: settings_terms_path, method: :patch, local: true do |f| %>
  <div class="card bg-base-100 shadow-sm">
    <div class="card-body space-y-6">
      <div class="form-control">
        <%= f.label :terms_content, "Regulamin", class: "label" %>
        <%= f.text_area :terms_content, 
              value: @terms['terms_content'],
              rows: 15,
              class: "textarea textarea-bordered w-full font-mono text-sm" %>
      </div>
      <div class="form-control">
        <%= f.label :privacy_policy_content, "Polityka prywatności", class: "label" %>
        <%= f.text_area :privacy_policy_content, 
              value: @terms['privacy_policy_content'],
              rows: 15,
              class: "textarea textarea-bordered w-full font-mono text-sm" %>
      </div>
    </div>
  </div>
  <div class="flex justify-end gap-2 mt-6">
    <%= link_to "Anuluj", settings_root_path, class: "btn btn-ghost" %>
    <%= f.submit "Zapisz", class: "btn btn-primary" %>
  </div>
<% end %>