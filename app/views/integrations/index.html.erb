<div class="<%= header_class %>">
  <%= render "shared/page_header", title: "Integracje", subtitle: "Zarządzaj połączeniami z zewnętrznymi platformami" %>
  <%= link_to new_integration_path, class: "btn btn-primary w-full sm:w-auto" do %>
    <%= lucide_icon('plus', class: 'w-4 h-4') %>
    Dodaj integrację
  <% end %>
</div>
<% if @integrations.any? %>
  <div class="bg-base-100 rounded-xl border border-base-200 shadow-sm divide-y divide-base-200">
    <%= render partial: "integrations/integration_card", collection: @integrations, as: :integration %>
  </div>
<% else %>
  <%= render "integrations/empty_state" %>
<% end %>
