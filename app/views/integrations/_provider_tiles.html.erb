<% provider_groups = {
  "OMS"          => { icon: "layers",      providers: [
    { name: "Baselinker", key: "baselinker", available: true,  beta: false },
    { name: "Sellasist",  key: "sellasist",  available: false, beta: false }
  ]},
  "Social Media" => { icon: "users",       providers: [
    { name: "TikTok",    key: "tiktok",    available: false, beta: false },
    { name: "Facebook",  key: "facebook",  available: false, beta: false },
    { name: "Instagram", key: "instagram", available: false, beta: false }
  ]},
  "Płatności"    => { icon: "credit-card", providers: [
    { name: "PayU",       key: "payu",       available: true,  beta: true  },
    { name: "Przelewy24", key: "przelewy24", available: false, beta: false },
    { name: "Stripe",     key: "stripe",     available: false, beta: false }
  ]},
  "Przesyłki"    => { icon: "truck",       providers: [
    { name: "InPost", key: "inpost", available: false, beta: false },
    { name: "DHL",    key: "dhl",    available: false, beta: false },
    { name: "DPD",    key: "dpd",    available: false, beta: false }
  ]},
  "Faktury"      => { icon: "file-text",   providers: [
    { name: "Fakturownia", key: "fakturownia", available: false, beta: false },
    { name: "wFirma",      key: "wfirma",      available: false, beta: false }
  ]}
} %>
<div class="space-y-8">
  <% provider_groups.each do |group_name, group| %>
    <div>
      <h2 class="section-title mb-3 flex items-center gap-2">
        <%= lucide_icon(group[:icon], class: "w-4 h-4 text-base-content/50") %>
        <%= group_name %>
      </h2>
      <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-6 gap-3">
        <% group[:providers].each do |provider| %>
          <% if provider[:available] %>
            <%= link_to new_integration_path(provider: provider[:key]),
                  class: "relative flex flex-col items-center gap-2 p-4 bg-base-100 rounded-xl border border-base-200 hover:border-primary hover:shadow-md transition-all duration-200 group" do %>
              <% if provider[:beta] %>
                <span class="absolute top-2 right-2 badge badge-warning badge-xs">Beta</span>
              <% end %>
              <div class="w-12 h-12 rounded-xl bg-white border border-base-200 flex items-center justify-center overflow-hidden p-1.5">
                <img src="<%= integration_logo_url(provider[:key]) %>"
                     class="w-full h-full object-contain"
                     onerror="this.outerHTML='<span class=\'text-xs font-bold text-base-content/60\'><%= provider[:name].first(2).upcase %></span>'">
            </div>
            <span class="text-xs font-medium text-center leading-tight"><%= provider[:name] %></span>
          <% end %>
        <% else %>
          <div class="relative flex flex-col items-center gap-2 p-4 bg-base-100 rounded-xl border border-base-200 opacity-40 cursor-default">
            <span class="absolute top-2 right-2 badge badge-ghost badge-xs">Soon</span>
            <div class="w-12 h-12 rounded-xl bg-white border border-base-200 flex items-center justify-center overflow-hidden p-1.5">
              <img src="<%= integration_logo_url(provider[:key]) %>"
                     class="w-full h-full object-contain"
                     onerror="this.outerHTML='<span class=\'text-xs font-bold text-base-content/40\'><%= provider[:name].first(2).upcase %></span>'">
          </div>
          <span class="text-xs font-medium text-center leading-tight"><%= provider[:name] %></span>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
<% end %>
</div>
