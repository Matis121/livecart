<% if params[:provider].present? %>
  <div class="<%= header_class("mb-6") %>">
    <%= render "shared/page_header",
        title: "Dodaj integrację: #{@integration.provider_name}",
        back_path: new_integration_path,
        back_label: "Powrót do wyboru platformy" %>
  </div>
  <%= render "form", integration: @integration %>
<% else %>
  <div class="mb-8">
    <%= render "shared/page_header",
        title: "Wybierz platformę",
        subtitle: "Wybierz system, z którym chcesz zintegrować LiveCart",
        back_path: integrations_path,
        back_label: "Powrót do integracji" %>
  </div>
  <%= render "provider_tiles" %>
<% end %>
